<Window x:Class="WinIsland.FocusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusOverlay" 
        WindowState="Maximized" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="#01000000" 
        Topmost="True" 
        ShowInTaskbar="False"
        IsHitTestVisible="True"
        MouseDown="Window_MouseDown">
    
    <Window.Resources>
        <Storyboard x:Key="BreathingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GlowBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                             From="10" To="60" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="GlowBorder" BorderThickness="12" Opacity="0" IsHitTestVisible="False">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFB75E" Offset="0"/>
                <GradientStop Color="#ED8F03" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#ED8F03" BlurRadius="50" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>
    </Border>
</Window>
