<Window x:Class="WinIsland.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinIsland Settings"
        Width="1120"
        Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        WindowStyle="None"
        AllowsTransparency="False"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="BrutalCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="8" BlurRadius="0" Opacity="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="BrutalButton" TargetType="Button">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" ShadowDepth="6" BlurRadius="0" Opacity="1"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CCFF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BrutalButton}">
            <Setter Property="Background" Value="#FF006E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border x:Name="SwitchTrack" Grid.Column="1" Width="68" Height="28" BorderBrush="#000000" BorderThickness="3" Background="#FFFFFF">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" ShadowDepth="4" BlurRadius="0" Opacity="1"/>
                                </Border.Effect>
                                <Grid>
                                    <TextBlock x:Name="TxtOff" Text="OFF" FontFamily="Consolas" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtOn" Text="ON" FontFamily="Consolas" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <Ellipse x:Name="Knob" Width="18" Height="18" Fill="#000000" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#CCFF00"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,4,0"/>
                                <Setter TargetName="TxtOn" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="TxtOff" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PickerButton" TargetType="Button" BasedOn="{StaticResource BrutalButton}">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>

        <Style x:Key="PopupOptionButton" TargetType="Button" BasedOn="{StaticResource BrutalButton}">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="52"/>
        </Style>

        <Style x:Key="DialHourButton" TargetType="Button">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CCFF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="84"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#000000" BorderThickness="0,0,0,4" Background="#FFFFFF">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="RAW SETTINGS" FontFamily="Segoe UI Black" FontSize="32" Foreground="#000000"/>
                    <TextBlock Text="NEO BRUTAL - WHITE THEME" FontFamily="Consolas" Foreground="#222222" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Width="42" Height="42" Content="✕" Click="Cancel_Click" Style="{StaticResource BrutalButton}" Background="#00D9FF"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="22,14,22,14" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkMessageNotification" Content="应用消息通知" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkBluetoothNotification" Content="蓝牙设备通知" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkUsbNotification" Content="USB 设备通知" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkCleanSystemNotification" Content="接管系统通知中心" Style="{StaticResource ToggleSwitchStyle}" Checked="ChkCleanSystemNotification_Checked"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="MEDIA" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkShowMediaPlayer" Content="显示媒体播放器" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkShowVisualizer" Content="音频可视化" Style="{StaticResource ToggleSwitchStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="SYSTEM" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkStartWithWindows" Content="开机自启动" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkEnableAutoHide" Content="智能隐藏" Style="{StaticResource ToggleSwitchStyle}"/>
                            <CheckBox x:Name="ChkSystemMonitor" Content="待机显示系统监控" Style="{StaticResource ToggleSwitchStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="FOCUS" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkFocusMode" Content="双击灵动岛开启番茄钟" Style="{StaticResource ToggleSwitchStyle}" Checked="ChkFocusMode_Checked" Unchecked="ChkFocusMode_Checked"/>
                            <StackPanel x:Name="PanelFocusSettings" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                                <TextBlock Text="时长(分钟)" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtPomodoroDuration" Width="100" Style="{StaticResource InputStyle}" PreviewTextInput="NumberValidationTextBox"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="WATER" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkDrinkWater" Content="启用喝水提醒" Style="{StaticResource ToggleSwitchStyle}" Checked="ChkDrinkWater_Checked" Unchecked="ChkDrinkWater_Unchecked"/>

                            <StackPanel x:Name="PanelDrinkWaterSettings" Visibility="Collapsed" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="RbModeInterval" Content="间隔模式" GroupName="Mode" IsChecked="True" Foreground="#000000" Margin="0,0,14,0" Checked="RbMode_Checked"/>
                                    <RadioButton x:Name="RbModeCustom" Content="自定义时间" GroupName="Mode" Foreground="#000000" Checked="RbMode_Checked"/>
                                </StackPanel>

                                <StackPanel x:Name="PanelModeInterval">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="86"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="间隔" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="TxtDrinkWaterInterval" Style="{StaticResource InputStyle}"/>
                                        <TextBlock Grid.Column="3" Text="活跃" Style="{StaticResource LabelStyle}"/>
                                        <Button Grid.Column="4" x:Name="BtnDrinkStartTime" Content="09:00" Style="{StaticResource PickerButton}" Click="BtnDrinkStartTime_Click"/>
                                        <TextBlock Grid.Column="5" Text="-" Foreground="#000000" VerticalAlignment="Center"/>
                                        <Button Grid.Column="6" x:Name="BtnDrinkEndTime" Content="22:00" Style="{StaticResource PickerButton}" Click="BtnDrinkEndTime_Click"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="PanelModeCustom" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCustomDrinkTime" Grid.Column="0" Content="选择时间" Style="{StaticResource PickerButton}" Click="BtnCustomDrinkTime_Click"/>
                                        <Button Grid.Column="1" Margin="8,0,0,0" Content="添加" Click="BtnAddCustomDrinkTime_Click" Style="{StaticResource BrutalButton}" Background="#00D9FF"/>
                                    </Grid>

                                    <ItemsControl x:Name="ListCustomDrinkTimes">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFFFFF" BorderBrush="#000000" BorderThickness="3" Padding="8" Margin="0,0,0,6">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" ShadowDepth="4" BlurRadius="0" Opacity="1"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <TextBlock Text="{Binding}" Foreground="#000000" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                        <Button HorizontalAlignment="Right" Content="删除" Tag="{Binding}" Click="BtnDeleteCustomDrinkTime_Click" Style="{StaticResource BrutalButton}" Padding="10,4" Background="#FF9500"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource BrutalCard}">
                        <StackPanel>
                            <TextBlock Text="TODO" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkTodo" Content="启用待办提醒" Style="{StaticResource ToggleSwitchStyle}" Checked="ChkTodo_Checked" Unchecked="ChkTodo_Unchecked"/>

                            <StackPanel x:Name="PanelTodo" Visibility="Collapsed" Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnTodoDate" Grid.Column="0" Margin="0,0,8,0" Content="2026-01-01" Style="{StaticResource PickerButton}" Click="BtnTodoDate_Click"/>
                                    <Button x:Name="BtnTodoTime" Grid.Column="1" Margin="0,0,8,0" Content="09:00" Style="{StaticResource PickerButton}" Click="BtnTodoTime_Click"/>
                                    <TextBox x:Name="TxtTodoContent" Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource InputStyle}"/>
                                    <Button Grid.Column="3" Content="添加" Click="BtnAddTodo_Click" Style="{StaticResource BrutalButton}" Background="#CCFF00"/>
                                </Grid>

                                <ItemsControl x:Name="ListTodo">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFFFF" BorderBrush="#000000" BorderThickness="3" Padding="8" Margin="0,0,0,6">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" ShadowDepth="4" BlurRadius="0" Opacity="1"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ReminderTime, StringFormat='yyyy-MM-dd HH:mm'}" Foreground="#000000" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Content}" Foreground="#000000" Margin="8,0,8,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="2" Content="删除" Tag="{Binding}" Click="BtnDeleteTodo_Click" Style="{StaticResource BrutalButton}" Padding="10,4" Background="#FF9500"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="#000000" BorderThickness="0,4,0,0" Background="#FFFFFF">
            <Grid Margin="22,0">
                <TextBlock VerticalAlignment="Center" Text="WinIsland / Neo Brutal White" Foreground="#000000" FontFamily="Consolas"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="取消" Click="Cancel_Click" Style="{StaticResource BrutalButton}" Width="112" Margin="0,0,8,0" Background="#00D9FF"/>
                    <Button Content="保存设置" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}" Width="136"/>
                </StackPanel>
            </Grid>
        </Border>

        <Popup x:Name="PopupTimeDial" StaysOpen="False" Placement="Center" PopupAnimation="Fade">
            <Border Background="#FFFFFF" BorderBrush="#000000" BorderThickness="4" Padding="12" Width="360">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="8" BlurRadius="0" Opacity="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="TxtDialTitle" Text="选择时间" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtDialValue" Text="09:00" FontFamily="Consolas" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Grid Width="300" Height="300" HorizontalAlignment="Center">
                        <Ellipse Stroke="#000000" StrokeThickness="3" Fill="#FFFFFF"/>
                        <Canvas x:Name="TimeDialCanvas" Width="300" Height="300"/>
                    </Grid>
                    <Grid Width="220" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="-" Style="{StaticResource BrutalButton}" Click="BtnMinuteDown_Click"/>
                        <Border Grid.Column="1" Margin="8,0" BorderBrush="#000000" BorderThickness="3" Background="#FFFFFF" Padding="4,4">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" ShadowDepth="4" BlurRadius="0" Opacity="1"/>
                            </Border.Effect>
                            <TextBox x:Name="TxtMinuteValue"
                                     Text="00"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontFamily="Consolas"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     BorderThickness="0"
                                     Background="#FFFFFF"
                                     MaxLength="2"
                                     PreviewTextInput="TxtMinuteValue_PreviewTextInput"
                                     LostFocus="TxtMinuteValue_LostFocus"
                                     KeyDown="TxtMinuteValue_KeyDown"/>
                        </Border>
                        <Button Grid.Column="2" Content="+" Style="{StaticResource BrutalButton}" Click="BtnMinuteUp_Click"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="取消" Style="{StaticResource BrutalButton}" Width="80" Margin="0,0,8,0" Click="BtnDialCancel_Click" Background="#00D9FF"/>
                        <Button Content="确定" Style="{StaticResource BrutalButton}" Width="80" Click="BtnDialOk_Click" Background="#CCFF00"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="PopupTodoDate" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnTodoDate}" PopupAnimation="Fade">
            <Border Background="#FFFFFF" BorderBrush="#000000" BorderThickness="4" Padding="10" Width="320">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="8" BlurRadius="0" Opacity="1"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="←" Width="34" Style="{StaticResource BrutalButton}" Click="BtnCalendarPrev_Click"/>
                        <TextBlock Grid.Column="1" x:Name="TxtCalendarTitle" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold" FontSize="16"/>
                        <Button Grid.Column="2" Content="→" Width="34" Style="{StaticResource BrutalButton}" Click="BtnCalendarNext_Click"/>
                    </Grid>
                    <UniformGrid x:Name="CalendarDayGrid" Columns="7" Rows="7"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
